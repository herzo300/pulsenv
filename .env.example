# База данных (SQLite по умолчанию)
DATABASE_URL=sqlite:///./soobshio.db
# Миграция на Supabase (https://xpainxohbdoruakcijyq.supabase.co): py scripts/setup/migrate_supabase.py
# SUPABASE_PROJECT_REF=xpainxohbdoruakcijyq
# SUPABASE_DB_PASSWORD=parol_iz_dashboard_Settings_Database
# SUPABASE_ACCESS_TOKEN ili SUPABASE — Management API token (dashboard/account/tokens), opcionalno dlya regiona
# DATABASE_URL=postgresql://postgres.xpainxohbdoruakcijyq:PAROL@aws-0-eu-central-1.pooler.supabase.com:6543/postgres
# Proksi dlya test_db_connection.py (opcionalno): pip install PySocks
# SOCKS_PROXY=socks5://127.0.0.1:1080
# HTTP_PROXY=http://127.0.0.1:8080

# Supabase Realtime для карты (опционально): Dashboard → Settings → API
# SUPABASE_URL=https://xpainxohbdoruakcijyq.supabase.co
# SUPABASE_ANON_KEY=eyJ...
# USE_SUPABASE_PRIMARY=true

# Telegram API (my.telegram.org)
TG_API_ID=your_api_id
TG_API_HASH=your_api_hash
TG_PHONE=+1234567890
TG_BOT_TOKEN=your_bot_token
TARGET_CHANNEL=@your_channel

# AI Провайдеры
# Z.AI API (primary для анализа текста и фото)
ZAI_API_KEY=your_zai_api_key
ZAI_BASE_URL=https://api.z.ai/api/paas/v4
ZAI_TEXT_MODEL=glm-4.7-flash

# Активный текстовый AI-провайдер: zai | keyword
AI_TEXT_PROVIDER=zai

# JWT Secret
JWT_SECRET=your_jwt_secret

# Firebase (legacy fallback)
FIREBASE_PROJECT_ID=your_project
FIREBASE_API_KEY=your_firebase_key
FIREBASE_RTDB_URL=https://your-firebase-rtdb.firebaseio.com

# Public API / Supabase Functions (вместо Cloudflare Worker)
PUBLIC_API_BASE_URL=http://127.0.0.1:8000
# Если не задано, будет вычислено как ${SUPABASE_URL}/functions/v1/api
SUPABASE_FUNCTIONS_URL=
# Для edge function /send-email
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev

# Legacy aliases (опционально, не рекомендуется)
# OPENAI_BASE_URL=${SUPABASE_FUNCTIONS_URL}/openai/v1

# VK API
VK_SERVICE_TOKEN=your_vk_token

# MCP Fetch Server (для веб-парсинга Telegram и VK)
MCP_FETCH_SERVER_URL=http://localhost:3000
MCP_FETCH_ENABLED=false
MCP_FETCH_TIMEOUT=30.0

# Открытые данные Нижневартовска
NV_OPENDATA_API_KEY=your_opendata_key



# Webhook (альтернатива polling — нет конфликта getUpdates)
# WEBHOOK_BASE_URL=https://your-domain.com  # HTTPS, для py scripts/maintenance/run_bot_webhook.py

# Администраторы Telegram бота (через запятую)
# Узнать свой ID: написать @userinfobot в Telegram
ADMIN_TELEGRAM_IDS=123456789,987654321

# Прокси (если прямое соединение недоступно — geo-блокировки)
# PROXY_URL=http://127.0.0.1:1080
# или SOCKS5: PROXY_HOST=host PROXY_PORT=1080 PROXY_USER=user PROXY_PASS=pass
# USE_PROXY_FOR_EXTERNAL=true — использовать прокси для OpenRouter, Firebase, VK

# Опционально: URL Telegram mini app для UVR5-UI (в админке /vocalremover)
# UVR5_MINIAPP_URL=https://your-domain/uvr5

# GitHub (деплой: py scripts/deployment/deploy_github.py)
# GITHUB=ghp_xxx   — Personal Access Token (repo)
# GITHUB_REPO=owner/repo   — например Rosomaxa3/pulsenv (по умолчанию herzo300/pulsenv)
